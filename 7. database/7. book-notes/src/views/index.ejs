<%- include('partials/header.ejs') %>

<div>
    <h1>Reader's Logbook</h1>
</div>

<div class="flex-between">
    <div class="flex-row">
        <button onclick="window.location.href='/books/add'">Add New Entry</button>
    </div>

    <form action="/books" method="get" class="inline-form">
        <label for="sorting-dropdown">Sort by:</label>
        <select name="sortBy" id="sorting-dropdown" onchange="this.form.submit()">
            <option value="title" <% if (sortOption === "title" || sortOption === undefined) { %>selected<% } %>>Title</option>
            <option value="created_at" <% if (sortOption === "created_at") { %>selected<% } %>>Date read</option>
            <option value="rating" <% if (sortOption === "rating") { %>selected<% } %>>Rating</option>
        </select>

        <select name="orderBy" id="ordering-dropdown" onchange="this.form.submit()">
            <option value="asc" <% if (orderOption === "asc" || orderOption === undefined) { %>selected<% } %>>Ascending</option>
            <option value="desc" <% if (orderOption === "desc") { %>selected<% } %>>Descending</option>
        </select>
    </form>
</div>

<% if (data && data.length !== 0) { %>
    <% for (let i=0; i<data.length; i++) { %>
<div class="grid-card">
    <div class="grid-left">
        <% if (data[i].image_url !== null) { %>
            <img src="<%= data[i].image_url %>" class="book-preview-img" alt="book cover image">
        <% } else { %>
            <div class="doodle-border" style="padding: 20px; text-align: center;">No Cover</div>
        <% } %>

        <div><strong>Date:</strong> <%=data[i].created_at.toLocaleDateString('en-GB', { timeZone: 'UTC' });%></div>

        <form action="/books/<%= data[i].id %>/notes" method="get" class="action-form">
            <button type="submit" style="width: 100%;">View Notes</button>
        </form>
        <form action="/books/<%= data[i].id %>?_method=DELETE" method="post" class="action-form">
            <button type="submit" style="width: 100%;" onclick="return confirm('Are you sure you want to delete this book?')">Delete Book</button>
        </form>
    </div>

    <div class="grid-right">
        <h2><%= data[i].title %></h2>
        <p><em>by <%= data[i].author %></em></p>

        <h3>Description</h3>
        <p><%- data[i].description %></p>

        <h3>My review</h3>
        <div class="flex-row">
            <% const rating = data[i].rating; %>
            <% for (let j=0; j<rating; j++) { %>
                <img src="styles/icon.png" class="star-icon" alt="filled star">
            <% } %>
        </div>

        <div id="review<%= data[i].id %>">
            <p><%- data[i].review %></p>
        </div>

        <form action="/books/<%= data[i].id %>?_method=PATCH" method="post" class="action-form hidden" id="editForm<%= data[i].id %>" style="display:flex; flex-direction:column; gap:10px;">
            <textarea name="review" autocomplete="off" autofocus="true"><%= data[i].review %></textarea>
            <button type="submit">Save Changes</button>
        </form>

        <div>
            <button id="update<%= data[i].id %>" type="button" onclick="handler('<%= data[i].id %>')">Edit Review</button>
        </div>
    </div>
</div>
    <% } %>
<% } else { %>
    <p>Book data not available.</p>
<% } %>

<script>
function handler(id) {
    document.getElementById("review" + id).classList.add("hidden");
    document.getElementById("update" + id).classList.add("hidden");
    document.getElementById("editForm" + id).classList.remove("hidden");
}
</script>
