<%- include('partials/header.ejs') %>

<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; text-align: center;">

    <img src="assets/images/bookshelf.png" alt="Bookshelf" style="max-width: 150px; opacity: 0.7; margin-bottom: 20px;">

    <h1>Oops! Something went wrong.</h1>

    <div class="doodle-border" style="padding: 30px; max-width: 500px; width: 100%; margin: 20px 0; background-color: #fffaf5;">

        <h2 style="color: #d9534f;">Error <%= status || '500' %></h2>
        <p class="entry-text" style="font-size: 1.2em;">
            <strong><%= message || 'An unexpected error occurred.' %></strong>
        </p>

    </div>

    <div class="flex-row" style="justify-content: center; margin-top: 20px;">
        <button onclick="window.history.back()">Go Back</button>
        <button onclick="window.location.href='/'">Return Home</button>
    </div>

</div>
